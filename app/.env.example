# Opcional (dev): si está definido, se usa como masterSeed y no se pide personal_sign.
# Sin esto, al conectar se firma una vez; la semilla vive solo en RAM hasta desconectar la wallet.
# VITE_GHOST_MASTER_SEED_HEX=

# Contrato GhostVault desplegado (requerido para mainnet/testnet distintos del default en código).
# VITE_GHOST_VAULT_ADDRESS=0x...
# Primer bloque con el contrato — puede ser hex (`0xa0948a`) o decimal (`10523786`).
# Ajustá al redeploy para no escanear toda la cadena.
# VITE_GHOST_VAULT_SCAN_FROM_BLOCK_HEX=0xa0948a

# --- Ethereum Sepolia (testing defaults; no secrets here — safe to copy into .env) ---
# Chain id 11155111 — must match RPC + deployed GhostVault.
VITE_CHAIN_ID=0xaa36a7
# MetaMask “Network name” when adding the chain:
VITE_CHAIN_NAME=Sepolia
# In-app label when the wallet is on the target chain:
VITE_CHAIN_DISPLAY_NAME=Sepolia
# Badge “Sepolia · testnet” on deposit / redeem (optional; omit to drop the tag):
VITE_WALLET_NETWORK_TAG=testnet
VITE_BLOCK_EXPLORER_URL=https://sepolia.etherscan.io
VITE_NATIVE_CURRENCY_SYMBOL=ETH
VITE_NATIVE_CURRENCY_NAME=Ether
VITE_NATIVE_CURRENCY_DECIMALS=18

# HTTP JSON-RPC + WebSocket (same network). WS is optional: if unset, vault activity uses HTTP only
# (see `getChainWsRpcUrl` in `ghostVaultLiveActivity.ts` — also tries wss://<host> for publicnode HTTPS URLs).
VITE_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Explicit WS (recommended for live logs if auto-derivation fails):
# VITE_PUBLIC_WS_RPC_URL=wss://ethereum-sepolia-rpc.publicnode.com
# Alias for the same vars (optional):
# VITE_ETHEREUM_RPC_URL=
# VITE_ETHEREUM_WS_RPC_URL=

# Compat: nombres antiguos Fuji siguen siendo leídos por `chainPublicRpc.ts`.
# VITE_FUJI_RPC_URL=
# VITE_FUJI_WS_RPC_URL=

# Tier público / free: cola JSON-RPC + espacio mínimo entre requests.
# VITE_PUBLIC_RPC_MIN_GAP_MS=150
# VITE_PUBLIC_RPC_MAX_RETRIES=4

# Escaneo vault (defaults en código pensados para RPC público: burst 5, pause 7500ms):
# VITE_GHOST_VAULT_RPC_BURST=5
# VITE_GHOST_VAULT_RPC_PAUSE_MS=7500
# VITE_GHOST_VAULT_SCAN_CACHE_MS=60000
# VITE_GHOST_VAULT_RPC_POLL_MS=15000
# Tamaño de batch (token indices por batch): default 5. Ej: 3 reduce llamadas por batch.
# VITE_GHOST_VAULT_TOKEN_BATCH_SIZE=3
# Índice mínimo para nuevos depósitos (default 2; deja 0-1 libres si aplica).
# VITE_GHOST_VAULT_MIN_NEW_DEPOSIT_TOKEN_INDEX=2

# Redeem (opcional): antes del primer "Start redeem", restringe qué cuenta ve el botón (prepare).
# Tras guardar borrador, se usa `prepareAccount` en localStorage y no hace falta.
# VITE_GHOST_REDEEM_PREPARE_ACCOUNT=

# Redeem (opcional): solo esta cuenta ve "Redeem here" (quien firma la tx en la wallet).
# VITE_GHOST_REDEEM_EXECUTOR_ACCOUNT=

# Debug: consola `[GhostVault activity]` (también activo en `npm run dev` sin esto).
# VITE_GHOST_VAULT_ACTIVITY_DEBUG=true

# Límite de batches para escanear índices de token / próximo depósito (default 128; max 10000).
# VITE_GHOST_VAULT_MAX_BATCHES=32
