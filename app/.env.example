# Opcional (dev): si está definido, se usa como masterSeed y no se pide personal_sign.
# Sin esto, al conectar se firma una vez; la semilla vive solo en RAM hasta desconectar la wallet.
# VITE_GHOST_MASTER_SEED_HEX=

# RPC Fuji (opcional): por defecto Infura Fuji; el proxy dev (`/fuji-rpc`) reenvía al mismo host.
# Podés sobreescribir con:
# VITE_FUJI_RPC_URL=https://avalanche-fuji.infura.io/v3/TU_PROJECT_ID
